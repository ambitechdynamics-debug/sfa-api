PORT=5000
DATABASE_URL=
JWT_SECRET=
JWT_EXPIRES_IN=7d
APP_URL=http://localhost:3000

# Optional seed admin account
ADMIN_FULL_NAME=Studio Flyer Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password
ADMIN_PHONE=

# ─── Phase 2 : AI Providers ───────────────────────────────
# Laisser vide pour utiliser le provider 'mock' en développement
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Provider par défaut : mock | openai | anthropic | gemini
AI_DEFAULT_TEXT_PROVIDER=mock
AI_DEFAULT_VISION_PROVIDER=mock

# Image generation (Nano Banana / Gemini Image)
# IMAGE_GEN_PROVIDER: "mock" (picsum.photos, no API key) | "gemini" (uses GEMINI_API_KEY)
# IMAGE_GEN_MODEL: Gemini image model name (only used when provider=gemini)
IMAGE_GEN_PROVIDER=mock
IMAGE_GEN_MODEL=gemini-2.5-flash-image-preview

# Modèle par défaut (ignoré en mode mock)
AI_DEFAULT_TEXT_MODEL=gpt-4o
AI_DEFAULT_VISION_MODEL=gpt-4o

# ─── Phase 3 : Cloudinary ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=studio-flyer-ai

# ─── Phase 4 : Neon Auth (vérification JWT via JWKS) ──────
# Activez Neon Auth sur https://console.neon.tech → onglet Auth, puis copiez
# l'URL "issuer" (= URL d'authentification) et l'URL JWKS depuis le panneau.
# Mettez NEON_AUTH_ENABLED=true pour activer ; laissez "false" pour rester
# sur l'ancien JWT pendant la migration.
NEON_AUTH_ENABLED=false
NEON_AUTH_ISSUER=
NEON_AUTH_JWKS_URL=
# Optionnel — laissez vide si Neon Auth n'émet pas d'audience spécifique.
NEON_AUTH_AUDIENCE=
